# Twitter Developer App (https://developer.twitter.com)
# Create an app with OAuth 2.0 enabled
# Set callback URL to: http://localhost:3001/auth/twitter/callback
TWITTER_CLIENT_ID=your_twitter_client_id_here
TWITTER_CLIENT_SECRET=your_twitter_client_secret_here
TWITTER_CALLBACK_URL=http://localhost:3001/auth/twitter/callback

# RapidAPI (https://rapidapi.com)
RAPIDAPI_KEY=your_rapidapi_key_here

# OpenAI (https://platform.openai.com) — used for embedding generation
OPENAI_API_KEY=your_openai_api_key_here

# Session
SESSION_SECRET=change_this_to_a_random_secret_string

# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/synapse

# URLs
FRONTEND_URL=http://localhost:5173
PORT=3001

# Stripe (one-time checkout)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx
STRIPE_PRICE_ID_STARTER_29=price_xxx
STRIPE_PRICE_ID_GROWTH_49=price_xxx
STRIPE_PRICE_ID_SCALE_79=price_xxx

# Admin whitelist credentials
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_this_password
